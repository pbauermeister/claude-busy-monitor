# Central path/pattern/marker config for .claude/hooks/* scripts.
#
# Shape: flat KEY=VALUE, shell-sourceable via `source`.  Python hooks
# load it through `hook_config.py` (same file, small parser).  Format is
# deliberately not sectioned INI — bash can't `source` section headers.
#
# Usage (shell):
#   DIR="$(cd "$(dirname "$0")" && pwd)"
#   # shellcheck disable=SC1091
#   source "$DIR/config.env"
#
# Usage (Python):
#   from hook_config import CONFIG
#   CONFIG["HOOK_RE_HOUSEKEEPING"]
#
# Conventions:
#   * All keys prefixed `HOOK_` to namespace.
#   * Values wrap in double quotes so shell preserves backslashes
#     and the Python loader can strip them uniformly.
#   * Regexes are ERE (grep -E) compatible; Python uses them as-is.

# --- Filesystem paths (relative to repo root) ---
HOOK_VENV_ACTIVATE_REL=".venv/bin/activate"
HOOK_PRETTIER_REL="node_modules/.bin/prettier"

# --- File-scope globs (shell `case` patterns) ---
HOOK_GLOB_MARKDOWN="*.md"
HOOK_GLOB_CLAUDE_MD="*CLAUDE.md"
HOOK_GLOB_DEVLOG="*/devlog/*"
HOOK_GLOB_CHARTER_UPPER="*CHARTER*"
HOOK_GLOB_CHARTER_LOWER="*charter*"

# --- Path substrings for Python endswith / `in` checks ---
HOOK_SUBSTR_CLAUDE_MD="/CLAUDE.md"
HOOK_SUBSTR_DEVLOG="/devlog/"
HOOK_SUBSTR_CHARTER_UPPER="CHARTER"
HOOK_SUBSTR_CHARTER_LOWER="charter"

# --- ERE regexes ---
# Housekeeping paths — files/dirs that may legitimately be committed on `main`
# without belonging to a task branch.  Matches:
#   * Specific root-level housekeeping files (TODO.md, Makefile, LICENSE,
#     CEREMONIES.md, MEMORY.md)
#   * Any top-level dotfile or dotdir (.gitignore, .prettierrc, .vscode/,
#     .claude/, .github/, etc.) — tooling/config conventionally lives here
#   * CLAUDE.md or HOWTO-*.md anywhere in the tree (governance content)
# README*.md is intentionally NOT housekeeping — top-level READMEs in this
# project are task-doc and follow task-branch discipline.
HOOK_RE_HOUSEKEEPING="^(TODO\.md|Makefile|LICENSE|CEREMONIES\.md|MEMORY\.md)$|^\.[^/]+(/|$)|(^|/)(CLAUDE\.md|HOWTO-[A-Z-]+\.md)$"
HOOK_RE_COAUTHOR_TRAILER="^(Authored-By|Co-Authored-By): "

# --- Review attestation markers (plain text; callers add anchors) ---
HOOK_MARKER_REVIEW_USER="- Review: user"
HOOK_MARKER_REVIEW_PENDING="- Review: pending"
HOOK_MARKER_AUTHOR_PREFIX="- Author:"
HOOK_MARKER_REVIEW_PREFIX="- Review:"

# --- Limits ---
HOOK_LIMIT_CLAUDE_MD_LINES=300
